# ---- LLM / embeddings ----
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ---- Postgres (admin connection used by migrations + ingestion) ----
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mcp
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/mcp

# ---- Read-only role used by sql_query MCP tool ----
# Created by alembic migration; this is the role the MCP SQL tool connects as.
READONLY_USER=mcp_readonly
READONLY_PASSWORD=mcp_readonly
READONLY_DATABASE_URL=postgresql+asyncpg://mcp_readonly:mcp_readonly@postgres:5432/mcp

# ---- SQL sandbox limits ----
SQL_STATEMENT_TIMEOUT_MS=5000
SQL_MAX_ROWS=500
SQL_MAX_QUERY_LEN=4000

# ---- HTTP transport (auth + rate limit) ----
HTTP_HOST=0.0.0.0
HTTP_PORT=8765
# Comma-separated API keys accepted on the HTTP transport. Empty disables HTTP auth (dev only).
MCP_API_KEYS=demo-key-please-rotate
# Token-bucket rate limit, per API key
RATE_LIMIT_TOKENS=60
RATE_LIMIT_REFILL_PER_SEC=1.0

# ---- Logging ----
LOG_LEVEL=INFO
